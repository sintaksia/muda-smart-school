generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id
  email        String     @unique
  name         String
  role         UserRole   @default(STUDENT)
  status       UserStatus @default(ACTIVE)
  avatar       String?
  phone        String?
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  createdById  String?    @map("created_by_id")
  createdBy    User?      @relation("CreatedByUser", fields: [createdById], references: [id])
  createdUsers User[]     @relation("CreatedByUser")
  student      Student?
  guru         Guru?

  @@map("users")
}

model Pendaftaran {
  id                 String            @id @default(cuid())
  namaLengkap        String            @map("nama_lengkap")
  jenisKelamin       JenisKelamin      @map("jenis_kelamin")
  programKeahlian    ProgramKeahlian   @map("program_keahlian")
  nisn               String            @unique
  nik                String            @unique
  nomorKk            String            @map("nomor_kk")
  tempatLahir        String            @map("tempat_lahir")
  tanggalLahir       DateTime          @map("tanggal_lahir")
  noHpMurid          String            @map("no_hp_murid")
  alamatJalan        String            @map("alamat_jalan")
  rt                 String
  rw                 String
  kelurahanDesa      String            @map("kelurahan_desa")
  kecamatan          String
  kotaKabupaten      String            @map("kota_kabupaten")
  provinsi           String
  kodePos            String?           @map("kode_pos")
  namaAyah           String            @map("nama_ayah")
  tahunLahirAyah     Int               @map("tahun_lahir_ayah")
  pendidikanAyah     Pendidikan        @map("pendidikan_ayah")
  pekerjaanAyah      String            @map("pekerjaan_ayah")
  namaIbu            String            @map("nama_ibu")
  tahunLahirIbu      Int               @map("tahun_lahir_ibu")
  pendidikanIbu      Pendidikan        @map("pendidikan_ibu")
  pekerjaanIbu       String            @map("pekerjaan_ibu")
  namaAsalSekolah    String            @map("nama_asal_sekolah")
  npsnAsalSekolah    String            @map("npsn_asal_sekolah")
  alamatAsalSekolah  String            @map("alamat_asal_sekolah")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  emailMurid         String?           @map("email_murid")
  hubunganWali       String?           @map("hubungan_wali")
  namaWali           String?           @map("nama_wali")
  noTelpAyah         String?           @map("no_telp_ayah")
  noTelpIbu          String?           @map("no_telp_ibu")
  noTelpWali         String?           @map("no_telp_wali")
  nomorPendaftaran   String            @unique @map("nomor_pendaftaran")
  pekerjaanWali      String?           @map("pekerjaan_wali")
  pendidikanWali     Pendidikan?       @map("pendidikan_wali")
  tahunLahirWali     Int?              @map("tahun_lahir_wali")
  status             StatusPendaftaran @default(PENDING)
  tahunLulus         Int               @map("tahun_lulus")
  tanggalPendaftaran DateTime          @default(now()) @map("tanggal_pendaftaran")
  student            Student?

  @@map("pendaftaran")
}

model Student {
  id              String          @id @default(cuid())
  userId          String          @unique @map("user_id")
  pendaftaranId   String?         @unique @map("pendaftaran_id")
  nis             String          @unique
  nisn            String          @unique
  programKeahlian ProgramKeahlian @map("program_keahlian")
  angkatan        Int
  kelasId         String?         @map("kelas_id")
  status          StudentStatus   @default(AKTIF)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  user         User           @relation(fields: [userId], references: [id])
  pendaftaran  Pendaftaran?   @relation(fields: [pendaftaranId], references: [id])
  kelas        Kelas?         @relation(fields: [kelasId], references: [id])
  absensiSiswa AbsensiSiswa[]

  @@map("students")
}

model Guru {
  id                   String            @id @default(cuid())
  userId               String            @unique @map("user_id")
  nip                  String?           @unique
  nuptk                String?           @unique
  jenisKelamin         JenisKelamin      @map("jenis_kelamin")
  tempatLahir          String            @map("tempat_lahir")
  tanggalLahir         DateTime          @map("tanggal_lahir")
  pendidikanTerakhir   Pendidikan        @map("pendidikan_terakhir")
  jabatan              String?
  statusKepegawaian    StatusKepegawaian @map("status_kepegawaian")
  tanggalMulaiMengajar DateTime?         @map("tanggal_mulai_mengajar")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  user          User                @relation(fields: [userId], references: [id])
  mataPelajaran GuruMataPelajaran[]
  kelasWali     Kelas[]
  jadwal        Jadwal[]
  absensiGuru   AbsensiGuru[]

  @@map("guru")
}

model Kelas {
  id              String          @id @default(cuid())
  nama            String
  tingkat         Int
  programKeahlian ProgramKeahlian @map("program_keahlian")
  tahunAjaran     String          @map("tahun_ajaran")
  waliKelasId     String?         @map("wali_kelas_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  waliKelas Guru?     @relation(fields: [waliKelasId], references: [id])
  students  Student[]
  jadwal    Jadwal[]

  @@unique([nama, tahunAjaran])
  @@map("kelas")
}

model MataPelajaran {
  id              String           @id @default(cuid())
  nama            String
  kode            String           @unique
  programKeahlian ProgramKeahlian? @map("program_keahlian")
  tingkat         Int?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  guru   GuruMataPelajaran[]
  jadwal Jadwal[]

  @@map("mata_pelajaran")
}

model GuruMataPelajaran {
  id              String @id @default(cuid())
  guruId          String @map("guru_id")
  mataPelajaranId String @map("mata_pelajaran_id")

  guru          Guru          @relation(fields: [guruId], references: [id])
  mataPelajaran MataPelajaran @relation(fields: [mataPelajaranId], references: [id])

  @@unique([guruId, mataPelajaranId])
  @@map("guru_mata_pelajaran")
}

model Jadwal {
  id              String   @id @default(cuid())
  kelasId         String   @map("kelas_id")
  mataPelajaranId String   @map("mata_pelajaran_id")
  guruId          String   @map("guru_id")
  hari            HariEnum
  jamMulai        String   @map("jam_mulai")
  jamSelesai      String   @map("jam_selesai")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  kelas         Kelas          @relation(fields: [kelasId], references: [id])
  mataPelajaran MataPelajaran  @relation(fields: [mataPelajaranId], references: [id])
  guru          Guru           @relation(fields: [guruId], references: [id])
  absensiSiswa  AbsensiSiswa[]
  absensiGuru   AbsensiGuru[]

  @@map("jadwal")
}

model AbsensiSiswa {
  id        String        @id @default(cuid())
  jadwalId  String        @map("jadwal_id")
  studentId String        @map("student_id")
  tanggal   DateTime
  status    AbsensiStatus
  catatan   String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  jadwal  Jadwal  @relation(fields: [jadwalId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([jadwalId, studentId, tanggal])
  @@map("absensi_siswa")
}

model AbsensiGuru {
  id        String        @id @default(cuid())
  jadwalId  String        @map("jadwal_id")
  guruId    String        @map("guru_id")
  tanggal   DateTime
  status    AbsensiStatus
  jamMasuk  DateTime?     @map("jam_masuk")
  catatan   String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  jadwal Jadwal @relation(fields: [jadwalId], references: [id])
  guru   Guru   @relation(fields: [guruId], references: [id])

  @@unique([jadwalId, guruId, tanggal])
  @@map("absensi_guru")
}

model HeroSlide {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  image     String
  ctaText   String?  @map("cta_text")
  ctaLink   String?  @map("cta_link")
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("hero_slides")
}

model Program {
  id           String            @id @default(cuid())
  name         String
  abbreviation String
  description  String
  color        String
  image        String?
  order        Int               @default(0)
  isActive     Boolean           @default(true) @map("is_active")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  careers      ProgramCareer[]
  facilities   ProgramFacility[]
  skills       ProgramSkill[]

  @@map("programs")
}

model ProgramSkill {
  id        String   @id @default(cuid())
  programId String   @map("program_id")
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("program_skills")
}

model ProgramCareer {
  id        String   @id @default(cuid())
  programId String   @map("program_id")
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("program_careers")
}

model ProgramFacility {
  id        String   @id @default(cuid())
  programId String   @map("program_id")
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("program_facilities")
}

model News {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String
  excerpt     String?
  image       String?
  category    String
  isFeatured  Boolean   @default(false) @map("is_featured")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("news")
}

model Testimonial {
  id        String          @id @default(cuid())
  name      String
  role      String
  quote     String
  type      TestimonialType
  image     String?
  order     Int             @default(0)
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("testimonials")
}

model Achievement {
  id          String           @id @default(cuid())
  title       String
  event       String
  level       AchievementLevel
  medalType   MedalType?       @map("medal_type")
  year        Int
  image       String?
  order       Int              @default(0)
  isHighlight Boolean          @default(false) @map("is_highlight")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("achievements")
}

model Gallery {
  id          String          @id @default(cuid())
  title       String
  description String?
  image       String
  category    GalleryCategory
  order       Int             @default(0)
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("gallery")
}

model Facility {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  images      String[] @default([])
  order       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("facilities")
}

model Extracurricular {
  id          String         @id @default(cuid())
  name        String
  description String?
  category    EkskulCategory
  icon        String?
  image       String?
  order       Int            @default(0)
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@map("extracurriculars")
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("faqs")
}

model Contact {
  id          String      @id @default(cuid())
  name        String
  value       String
  type        ContactType
  description String?
  order       Int         @default(0)
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("contacts")
}

model SocialLink {
  id        String         @id @default(cuid())
  platform  SocialPlatform
  url       String
  username  String?
  order     Int            @default(0)
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@map("social_links")
}

model AiChatSetting {
  id             String   @id @default(cuid())
  systemPrompt   String   @map("system_prompt")
  welcomeMessage String   @default("Halo! Saya asisten virtual SMK Muhammadiyah 2 Cibiru. Ada yang bisa saya bantu? 😊") @map("welcome_message")
  suggestions    String[] @default([])
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("ai_chat_settings")
}

model SchoolSetting {
  id        String      @id @default(cuid())
  key       String      @unique
  value     String
  type      SettingType @default(TEXT)
  label     String
  group     String      @default("general")
  order     Int         @default(0)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("school_settings")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum ProgramKeahlian {
  TEKNIK_OTOMOTIF
  PEMROGRAMAN_PERANGKAT_LUNAK_DAN_GIM
  TEKNIK_JARINGAN_KOMPUTER_DAN_TELEKOMUNIKASI
  MANAJEMEN_PERKANTORAN_DAN_LAYANAN_BISNIS
  AKUNTANSI_DAN_KEUANGAN_LEMBAGA
}

enum Pendidikan {
  SD
  SMP
  SMA
  SMK
  D1
  D2
  D3
  D4
  S1
  S2
  S3
  TIDAK_SEKOLAH
}

enum TestimonialType {
  ALUMNI
  ORANG_TUA
  GURU
  MITRA
}

enum MedalType {
  GOLD
  SILVER
  BRONZE
  JUARA_1
  JUARA_2
  JUARA_3
  HARAPAN_1
  HARAPAN_2
  HARAPAN_3
}

enum AchievementLevel {
  INTERNASIONAL
  NASIONAL
  PROVINSI
  KOTA
  KECAMATAN
  SEKOLAH
}

enum GalleryCategory {
  FASILITAS
  KEGIATAN
  PRESTASI
  EKSKUL
  LAINNYA
}

enum EkskulCategory {
  ORGANISASI
  KEPANDUAN
  BELADIRI
  OLAHRAGA
  SENI
  AKADEMIK
  KEAGAMAAN
  LAINNYA
}

enum ContactType {
  WHATSAPP
  PHONE
  EMAIL
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  TWITTER
  TIKTOK
  LINKEDIN
  WEBSITE
}

enum SettingType {
  TEXT
  TEXTAREA
  HTML
  JSON
  IMAGE
  NUMBER
  BOOLEAN
}

enum StatusPendaftaran {
  PENDING
  DIVERIFIKASI
  DITOLAK
  DITERIMA
}

enum StudentStatus {
  AKTIF
  LULUS
  PINDAH
  DROPOUT
}

enum StatusKepegawaian {
  PNS
  PPPK
  GTY
  GTT
}

enum HariEnum {
  SENIN
  SELASA
  RABU
  KAMIS
  JUMAT
  SABTU
}

enum AbsensiStatus {
  HADIR
  SAKIT
  IZIN
  ALPHA
}
